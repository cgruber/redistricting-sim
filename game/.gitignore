# Bazel output symlinks
bazel-*

# Generated by wasm-bindgen
**/*_bg.wasm
**/*_bg.wasm.d.ts

# Node modules (managed by pnpm for lockfile generation only)
node_modules/

# Local dev serve output
_serve_dist/

# Deploy workspace and temporary build artifacts
.deploy/
.deploy_staging/
.deploy_prod/
.deploy_pkg/
_deploy_out/

# Playwright test output (traces, HTML report, error contexts)
web/test-results/

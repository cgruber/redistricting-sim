  "events": [],

  "rules": {
    "population_tolerance": 0.05,
    "contiguity": "required"
  },

  "success_criteria": [
    {
      "id": "sc-district-count",
      "required": true,
      "description": "Every precinct is assigned to a district, and both districts are in use.",
      "criterion": { "type": "district_count" }
    },
    {
      "id": "sc-population-balance",
      "required": true,
      "description": "Both districts have roughly equal population (within 5%).",
      "criterion": { "type": "population_balance" }
    },
    {
      "id": "sc-compactness",
      "required": false,
      "description": "Both districts have compact, reasonable shapes — no extreme salamander outlines.",
      "criterion": { "type": "compactness", "operator": "gte", "threshold": 0.45 }
    }
  ],

  "narrative": {
    "character": {
      "name": "You",
      "role": "Redistricting Coordinator, Millbrook County",
      "motivation": "No political agenda — the census just came in, your supervisor handed you the map software, and there's a deadline. You just need to draw two legal districts."
    },
    "intro_slides": [
      {
        "heading": "Welcome to Redistricting",
        "body": "Every ten years, after the census, district boundaries get redrawn to reflect population changes. Millbrook County just got its new numbers — and someone has to draw the lines.\n\nThat someone is you."
      },
      {
        "heading": "Your job is simple (in theory)",
        "body": "New Texifornia elects State House representatives by district. Your task: divide Millbrook County's precincts into two districts with roughly equal population.\n\nThe county doesn't care which party wins — it just needs a valid map."
      }
    ],
    "objective": "Divide Millbrook County into 2 districts with equal population. Every precinct must be assigned. Both districts must be contiguous."
  }
}
